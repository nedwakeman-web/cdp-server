# Copy this to .env and fill in your values
# NEVER commit .env to git

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# JWT signing secret - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate-a-long-random-string-here

# Database path
DB_PATH=./cdp.db

# Stripe (get from stripe.com/dashboard)
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_SEEKER=price_xxx
STRIPE_PRICE_INITIATE=price_xxx
STRIPE_PRICE_MYSTIC=price_xxx
STRIPE_PRICE_ORACLE=price_xxx
STRIPE_PRICE_BESPOKE=price_xxx

# Your frontend URL (for Stripe redirects and CORS)
APP_URL=https://cosmicdailyplanner.com
ALLOWED_ORIGINS=https://cosmicdailyplanner.com,http://localhost:3000

# Port (Railway sets this automatically)
PORT=3001
